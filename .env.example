PORT=3900
HOST=127.0.0.1

# Path to the qwen-code monorepo root (where packages/cli lives).
# For dev, point at your local checkout. For production, bundle the CLI and
# set QWEN_CODE_BIN to the bundled binary instead.
QWEN_CODE_ROOT=/media/data/fun-noSync/tools/qwen-code

# Optional: absolute path to a built qwen binary. If set, takes precedence
# over QWEN_CODE_ROOT and is invoked directly.
# QWEN_CODE_BIN=/opt/qwen-code/dist/index.js

# Where to store per-user workspaces and admin-owned settings trees.
DATA_DIR=./data

# SQLite database file.
DB_PATH=./data/qwen-web.sqlite

# Session cookie secret (change in production — 32+ random bytes).
COOKIE_SECRET=please-change-me-to-a-random-32-byte-hex-string

# Upstream auth passed to the spawned qwen CLI.
# For now a single provider/key is shared by all users.
QWEN_AUTH_TYPE=openai
# OPENAI_API_KEY=sk-...

# Concurrency limits.
MAX_SESSIONS_PER_USER=2
MAX_SESSIONS_TOTAL=20

# Auth mode: 'users' requires login via SQLite-backed accounts (cookie session).
# 'anonymous' keeps a single shared session with no login — useful for local dev.
AUTH_MODE=users
SESSION_TTL_SECONDS=43200
ADMIN_USERNAME=admin
# Seed password for the first-boot admin. If unset, a random password is
# generated and printed to stderr the first time the server starts.
# ADMIN_INITIAL_PASSWORD=

# Baseline denylist applied to every 'user' role account. Per-user overrides
# from the admin API get UNION-merged on top of this.
# ROLE_USER_DISABLED_SLASH_COMMANDS=init,clear

# Sandbox: 'none' runs qwen directly (simpler, no isolation beyond HOME/cwd).
# 'bwrap' wraps each qwen process in bubblewrap so it only sees its own
# workspace + HOME + a minimal read-only system (/usr, /lib, etc). Prevents
# the model's shell/read_file tools and !{cmd} from reaching host files.
# Requires the 'bubblewrap' package installed on the host.
SANDBOX_MODE=none

# Comma-separated system paths to expose read-only in the sandbox. Defaults
# are sensible for Debian/Ubuntu/Arch; override if your distro puts things
# elsewhere.
# SANDBOX_RO_BINDS=/usr,/lib,/lib32,/lib64,/bin,/sbin,/etc/ssl,/etc/ca-certificates,/etc/resolv.conf,/etc/nsswitch.conf,/etc/hosts,/etc/hostname,/etc/localtime

# Extra read-only binds, e.g. for custom toolchain paths referenced by qwen
# hooks or tools. Added on top of SANDBOX_RO_BINDS.
# SANDBOX_EXTRA_RO_BINDS=/opt/tools

# Share the host's network namespace so qwen can reach the LLM endpoint.
# Set to 'false' for a fully offline sandbox (qwen won't reach anything).
SANDBOX_SHARE_NET=true
